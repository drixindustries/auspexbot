# ── Required ──────────────────────────────────────────────────────────────

# From @BotFather
BOT_TOKEN=your_telegram_bot_token

# Your private Telegram channel ID (starts with -100...)
# Get it by adding @userinfobot to the channel
CHANNEL_ID=-1001234567890

# Optional: public invite link for the channel (fallback if invite link creation fails)
CHANNEL_LINK=https://t.me/+your_invite_hash

# Supabase (use your existing project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Payment receive wallets (generate fresh dedicated wallets for this)
BASE_RECEIVE_ADDR=0x_your_base_wallet_address
SOLANA_RECEIVE_ADDR=your_solana_wallet_address

# ── Optional but recommended ───────────────────────────────────────────────

# Alchemy Base RPC (better reliability than public RPC)
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/your_key

# Helius for Solana tx verification (free tier works fine)
HELIUS_API_KEY=your_helius_api_key

# Anthropic API key — enables all 4 AI agents
# Get from console.anthropic.com — ~$3/month at normal usage
ANTHROPIC_API_KEY=your_anthropic_api_key

# Your personal Telegram user ID — restricts /addaccount, /watchlist to you only
# Get it by messaging @userinfobot on Telegram
OWNER_TELEGRAM_ID=your_telegram_user_id

# ── X Follow Watcher ────────────────────────────────────────────────────────

# X (Twitter) API Bearer token — requires Basic tier ($100/month)
# Get from developer.twitter.com → Your App → Keys and Tokens
# Without this, Nitter fallback is used instead
X_BEARER_TOKEN=your_x_bearer_token

# Elfa AI API key — smart follower weight data (free tier: 1,000 credits/month)
# Get from elfa.ai/api — free tier is enough to start
ELFA_API_KEY=your_elfa_api_key

# Dedicated Telegram channel for X follow alerts
# Create a private channel, add the bot as admin, get the ID via @userinfobot
FOLLOW_CHANNEL_ID=-1009999999999
